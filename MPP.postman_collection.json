{
  "info": {
    "name": "MPP — Machine Payments Protocol",
    "description": "Full MPP flow: save card → get 402 challenge → charge card via /charges → retry with one-time token → get 200 + receipt.\n\n## Setup\n1. Start server: `npx tsx examples/server.ts`\n2. Import this collection\n3. Run requests in order, or use Collection Runner\n\n**Auto-Pay requests** handle the entire flow with pre-request scripts — just click Send.",
    "_postman_id": "mpp-collection-002",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3402" },
    { "key": "agent_id", "value": "agent-001" },
    { "key": "card_id", "value": "" },
    { "key": "challenge_json", "value": "" },
    { "key": "payment_token", "value": "" },
    { "key": "credential_b64", "value": "" },
    { "key": "auto_credential_b64", "value": "" }
  ],
  "item": [
    {
      "name": "1 — Discovery",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/.well-known/mpp", "host": ["{{base_url}}"], "path": [".well-known", "mpp"] },
        "description": "MPP discovery document. Shows available payment methods and API endpoints."
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "pm.test('Status 200', () => pm.response.to.have.status(200));",
          "pm.test('Has version and endpoints', () => {",
          "  const body = pm.response.json();",
          "  pm.expect(body.version).to.equal('1.0');",
          "  pm.expect(body.endpoints.charges).to.equal('/charges');",
          "  pm.expect(body.endpoints.vault).to.equal('/vault/cards');",
          "});"
        ]}
      }]
    },
    {
      "name": "2 — Save Card to Vault",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/vault/cards", "host": ["{{base_url}}"], "path": ["vault", "cards"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"{{agent_id}}\",\n  \"card_number\": \"4242424242424242\",\n  \"exp_month\": 12,\n  \"exp_year\": 2028,\n  \"cvc\": \"123\"\n}"
        },
        "description": "Save a card to the vault. Returns a tokenized card ID (no raw numbers stored)."
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "pm.test('Status 201', () => pm.response.to.have.status(201));",
          "pm.test('Card saved', () => {",
          "  const body = pm.response.json();",
          "  pm.expect(body.id).to.match(/^card_/);",
          "  pm.expect(body.last4).to.equal('4242');",
          "  pm.expect(body.brand).to.equal('visa');",
          "  pm.collectionVariables.set('card_id', body.id);",
          "  console.log('Card saved:', body.id);",
          "});"
        ]}
      }]
    },
    {
      "name": "3 — List Saved Cards",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/vault/cards/{{agent_id}}", "host": ["{{base_url}}"], "path": ["vault", "cards", "{{agent_id}}"] },
        "description": "List all saved cards for this agent."
      },
      "event": [{
        "listen": "test",
        "script": { "type": "text/javascript", "exec": [
          "pm.test('Status 200', () => pm.response.to.have.status(200));",
          "pm.test('Has cards', () => {",
          "  const body = pm.response.json();",
          "  pm.expect(body).to.be.an('array');",
          "  pm.expect(body.length).to.be.greaterThan(0);",
          "});"
        ]}
      }]
    },
    {
      "name": "── Step-by-Step 402 Flow ──",
      "description": "Run these 4 requests in order to see each step of the protocol.",
      "item": [
        {
          "name": "4a — Hit endpoint, get 402 + challenge",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=hello", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "hello"}] },
            "description": "No payment credential → server returns 402 with a cryptographic challenge."
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 402', () => pm.response.to.have.status(402));",
              "pm.test('Has WWW-Authenticate', () => {",
              "  pm.expect(pm.response.headers.get('WWW-Authenticate')).to.include('Payment');",
              "});",
              "pm.test('Has challenge in body', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.challenge.id).to.be.a('string');",
              "  pm.expect(body.challenge.method).to.equal('card');",
              "  pm.collectionVariables.set('challenge_json', JSON.stringify(body.challenge));",
              "  console.log('Challenge stored:', body.challenge.id.slice(0, 30) + '...');",
              "});"
            ]}
          }]
        },
        {
          "name": "4b — POST /charges → get one-time token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/charges", "host": ["{{base_url}}"], "path": ["charges"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"challenge\": {{challenge_json}},\n  \"card_id\": \"{{card_id}}\"\n}" },
            "description": "Send the challenge + saved card ID. Server charges the card and returns a one-time token."
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has token', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.token).to.match(/^tok_/);",
              "  pm.expect(body.amount).to.equal('0.01');",
              "  pm.collectionVariables.set('payment_token', body.token);",
              "  console.log('Token:', body.token);",
              "});"
            ]}
          }]
        },
        {
          "name": "4c — Retry with token → get 200 + receipt",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=hello", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "hello"}] },
            "header": [{ "key": "Authorization", "value": "Payment {{credential_b64}}" }],
            "description": "Retry the same request with the one-time token. Pre-request script builds the credential."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const challenge = JSON.parse(pm.collectionVariables.get('challenge_json'));",
                "const token = pm.collectionVariables.get('payment_token');",
                "if (!challenge || !token) throw new Error('Run 4a and 4b first');",
                "",
                "const credential = {",
                "  challenge: challenge,",
                "  source: pm.collectionVariables.get('agent_id'),",
                "  payload: { token: token }",
                "};",
                "",
                "const b64 = btoa(JSON.stringify(credential)).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');",
                "pm.collectionVariables.set('credential_b64', b64);"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has Payment-Receipt', () => {",
                "  pm.expect(pm.response.headers.get('Payment-Receipt')).to.be.a('string');",
                "});",
                "pm.test('Has search results', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.results).to.be.an('array');",
                "  pm.expect(body._payment.receipt_id).to.be.a('string');",
                "  pm.expect(body._payment.amount).to.equal('0.01');",
                "});",
                "",
                "// Decode receipt",
                "const rh = pm.response.headers.get('Payment-Receipt');",
                "if (rh) {",
                "  try {",
                "    const padded = rh + '='.repeat((4 - rh.length % 4) % 4);",
                "    const receipt = JSON.parse(atob(padded.replace(/-/g, '+').replace(/_/g, '/')));",
                "    console.log('Receipt:', JSON.stringify(receipt, null, 2));",
                "  } catch(e) {}",
                "}"
              ]}
            }
          ]
        },
        {
          "name": "4d — Replay same token (should fail)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=hello", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "hello"}] },
            "header": [{ "key": "Authorization", "value": "Payment {{credential_b64}}" }],
            "description": "Replay the exact same credential. Should be rejected — token is one-time use."
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Replay rejected', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([403, 402]);",
              "});",
              "pm.test('Error type indicates invalid', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.type).to.match(/invalid/);",
              "});"
            ]}
          }]
        }
      ]
    },
    {
      "name": "── Auto-Pay (one click) ──",
      "description": "Pre-request scripts handle everything: 402 → /charges → build credential. Just click Send.",
      "item": [
        {
          "name": "Search — auto-pay ($0.01)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=machine+payments", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "machine payments"}] },
            "header": [{ "key": "Authorization", "value": "Payment {{auto_credential_b64}}" }],
            "description": "One-click paid search. Pre-request script does: GET → 402 → POST /charges → build credential."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const baseUrl = pm.collectionVariables.get('base_url');",
                "const cardId = pm.collectionVariables.get('card_id');",
                "const agentId = pm.collectionVariables.get('agent_id');",
                "",
                "if (!cardId) throw new Error('Save a card first (request #2)');",
                "",
                "// Step 1: Get 402 challenge",
                "pm.sendRequest(baseUrl + '/api/search?q=machine+payments', (err, res) => {",
                "  if (res.code !== 402) { console.log('Expected 402, got:', res.code); return; }",
                "  const challenge = res.json().challenge;",
                "",
                "  // Step 2: Charge card",
                "  pm.sendRequest({",
                "    url: baseUrl + '/charges',",
                "    method: 'POST',",
                "    header: { 'Content-Type': 'application/json' },",
                "    body: { mode: 'raw', raw: JSON.stringify({ challenge, card_id: cardId }) }",
                "  }, (err2, res2) => {",
                "    if (res2.code !== 200) { console.log('Charge failed:', res2.code); return; }",
                "    const token = res2.json().token;",
                "",
                "    // Step 3: Build credential",
                "    const credential = {",
                "      challenge: challenge,",
                "      source: agentId,",
                "      payload: { token: token }",
                "    };",
                "    const b64 = btoa(JSON.stringify(credential)).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');",
                "    pm.collectionVariables.set('auto_credential_b64', b64);",
                "    console.log('Ready: token=' + token.slice(0, 20) + '...');",
                "  });",
                "});"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has receipt', () => pm.expect(pm.response.headers.get('Payment-Receipt')).to.be.a('string'));",
                "pm.test('Has results', () => pm.expect(pm.response.json().results).to.be.an('array'));"
              ]}
            }
          ]
        },
        {
          "name": "Premium — auto-pay ($1.00)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/premium", "host": ["{{base_url}}"], "path": ["api", "premium"] },
            "header": [{ "key": "Authorization", "value": "Payment {{auto_credential_b64}}" }],
            "description": "One-click premium access."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const baseUrl = pm.collectionVariables.get('base_url');",
                "const cardId = pm.collectionVariables.get('card_id');",
                "const agentId = pm.collectionVariables.get('agent_id');",
                "",
                "if (!cardId) throw new Error('Save a card first (request #2)');",
                "",
                "pm.sendRequest(baseUrl + '/api/premium', (err, res) => {",
                "  if (res.code !== 402) return;",
                "  const challenge = res.json().challenge;",
                "",
                "  pm.sendRequest({",
                "    url: baseUrl + '/charges',",
                "    method: 'POST',",
                "    header: { 'Content-Type': 'application/json' },",
                "    body: { mode: 'raw', raw: JSON.stringify({ challenge, card_id: cardId }) }",
                "  }, (err2, res2) => {",
                "    if (res2.code !== 200) return;",
                "    const token = res2.json().token;",
                "    const credential = { challenge, source: agentId, payload: { token } };",
                "    const b64 = btoa(JSON.stringify(credential)).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');",
                "    pm.collectionVariables.set('auto_credential_b64', b64);",
                "  });",
                "});"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has receipt', () => pm.expect(pm.response.headers.get('Payment-Receipt')).to.be.a('string'));",
                "pm.test('Has content', () => pm.expect(pm.response.json().content).to.be.a('string'));"
              ]}
            }
          ]
        }
      ]
    },
    {
      "name": "── Error Cases ──",
      "item": [
        {
          "name": "Malformed credential",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=test", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "test"}] },
            "header": [{ "key": "Authorization", "value": "Payment bm90LXZhbGlk" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('Error type', () => pm.expect(pm.response.json().type).to.equal('urn:mpp:error:invalid-credential'));"
          ]}}]
        },
        {
          "name": "Wrong auth scheme (Bearer)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/search?q=test", "host": ["{{base_url}}"], "path": ["api", "search"], "query": [{"key": "q", "value": "test"}] },
            "header": [{ "key": "Authorization", "value": "Bearer some-jwt-token" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 402 (treated as no credential)', () => pm.response.to.have.status(402));",
            "pm.test('Returns challenge', () => pm.expect(pm.response.json().challenge).to.be.an('object'));"
          ]}}]
        },
        {
          "name": "Charge with bad card_id",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/charges", "host": ["{{base_url}}"], "path": ["charges"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"challenge\": {{challenge_json}},\n  \"card_id\": \"card_nonexistent\"\n}" },
            "description": "Try to charge a card that doesn't exist in the vault."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Charge fails', () => pm.expect(pm.response.code).to.be.oneOf([400, 402]));",
            "pm.test('Has error', () => pm.expect(pm.response.json().title).to.be.a('string'));"
          ]}}]
        }
      ]
    }
  ]
}
